# Copy to .env for local overrides (never commit real values).
# Production database (Supabase session-pooler URI). Unset = local DuckDB.
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-0-eu-west-2.pooler.supabase.com:5432/postgres

# Finnhub US intraday & catalyst layer (optional — everything continues to
# work from Yahoo + stored data when these are unset). Create the real key
# as the FINNHUB_API_KEY GitHub Actions secret; never commit or log it.
FINNHUB_API_KEY=replace_me
FINNHUB_ENABLED=false
# disabled | pilot (restricted evaluation universe) | production
# (production requires confirmed commercial-use licensing — see README)
FINNHUB_USAGE_MODE=pilot
